# Supabase (required)
VITE_SUPABASE_URL=your-project-url
VITE_SUPABASE_ANON_KEY=your-anon-key

# Supabase admin (for scripts, gitignored)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_PAT=your-personal-access-token
SUPABASE_PROJECT_REF=your-project-ref

# Services
RESEND_API_KEY=your-resend-key
GEMINI_API_KEY=your-gemini-key

# Logging (optional, client-side)
# VITE_LOG_LEVEL=debug  # Uncomment for verbose client-side logging. Options: debug, info, warn, error. Defaults to 'debug' in dev, 'warn' in production.
